<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.apkviewer.ApkViewerActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/spacing_xl"
            android:visibility="gone" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCertificate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/md_theme_surface_variant"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <!-- Issuer -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cert_issuer"
                    style="@style/FileInfoLabel" />

                <TextView
                    android:id="@+id/tvIssuer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/FileInfoValue"
                    android:layout_marginTop="@dimen/spacing_xs"
                    tools:text="CN=Android Debug, O=Android, C=US" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_color"
                    android:layout_marginVertical="@dimen/spacing_sm" />

                <!-- Subject -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cert_subject"
                    style="@style/FileInfoLabel" />

                <TextView
                    android:id="@+id/tvSubject"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/FileInfoValue"
                    android:layout_marginTop="@dimen/spacing_xs"
                    tools:text="CN=Android Debug, O=Android, C=US" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_color"
                    android:layout_marginVertical="@dimen/spacing_sm" />

                <!-- Valid From -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cert_valid_from"
                    style="@style/FileInfoLabel" />

                <TextView
                    android:id="@+id/tvValidFrom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/FileInfoValue"
                    android:layout_marginTop="@dimen/spacing_xs"
                    tools:text="2024-01-01" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_color"
                    android:layout_marginVertical="@dimen/spacing_sm" />

                <!-- Valid To -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cert_valid_to"
                    style="@style/FileInfoLabel" />

                <TextView
                    android:id="@+id/tvValidTo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/FileInfoValue"
                    android:layout_marginTop="@dimen/spacing_xs"
                    tools:text="2054-01-01" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_color"
                    android:layout_marginVertical="@dimen/spacing_sm" />

                <!-- Serial Number -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cert_serial_number"
                    style="@style/FileInfoLabel" />

                <TextView
                    android:id="@+id/tvSerialNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/md_theme_on_surface"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="@dimen/spacing_xs"
                    tools:text="ABC123DEF456" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_color"
                    android:layout_marginVertical="@dimen/spacing_sm" />

                <!-- Algorithm -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cert_algorithm"
                    style="@style/FileInfoLabel" />

                <TextView
                    android:id="@+id/tvAlgorithm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/FileInfoValue"
                    android:layout_marginTop="@dimen/spacing_xs"
                    tools:text="SHA256withRSA" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_color"
                    android:layout_marginVertical="@dimen/spacing_sm" />

                <!-- SHA-256 Fingerprint -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cert_sha256"
                    style="@style/FileInfoLabel" />

                <TextView
                    android:id="@+id/tvSha256"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/md_theme_on_surface"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:maxLines="4"
                    android:ellipsize="end"
                    tools:text="AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99:AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
