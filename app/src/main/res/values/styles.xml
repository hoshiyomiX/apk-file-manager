<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="RoundedCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/md_theme_surface_variant</item>
    </style>

    <style name="FileInfoLabel" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/md_theme_on_surface_variant</item>
    </style>

    <style name="FileInfoValue" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/md_theme_on_surface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TabTextAppearance" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
