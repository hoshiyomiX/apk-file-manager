<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootPanel"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.main.MainActivity">

    <!-- Unified Path Bar -->
    <LinearLayout
        android:id="@+id/unifiedPathBar"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/md_theme_surface"
        android:paddingStart="12dp"
        android:paddingEnd="4dp"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btnUnifiedUp"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_up"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/up"
            android:padding="6dp"
            app:tint="@color/md_theme_on_surface" />

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:scrollbars="none"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:layout_gravity="center_vertical">

            <TextView
                android:id="@+id/tvUnifiedPath"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="middle"
                android:textColor="@color/md_theme_on_surface"
                android:textSize="13sp"
                android:paddingVertical="2dp" />

        </HorizontalScrollView>

        <ImageButton
            android:id="@+id/btnPathCreateNew"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/path_bar_create_new"
            android:padding="6dp"
            app:tint="@color/md_theme_on_surface" />

        <ImageButton
            android:id="@+id/btnPathSort"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_sort"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/path_bar_sort"
            android:padding="6dp"
            app:tint="@color/md_theme_on_surface" />

        <ImageButton
            android:id="@+id/btnPathFilter"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_filter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/path_bar_filter"
            android:padding="6dp"
            app:tint="@color/md_theme_on_surface" />

    </LinearLayout>

    <!-- Dual Panel Container -->
    <LinearLayout
        android:id="@+id/dualPanelContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left Panel -->
        <LinearLayout
            android:id="@+id/leftPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@color/md_theme_background">

            <!-- Active Panel Indicator (Left) -->
            <View
                android:id="@+id/leftPanelIndicator"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="@color/md_theme_primary"
                android:visibility="visible" />

            <!-- Left Panel File List -->
            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipeLeftRefresh"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvLeftFiles"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:paddingVertical="@dimen/spacing_xs"
                        tools:listitem="@layout/item_file" />

                    <TextView
                        android:id="@+id/tvLeftEmpty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/empty_folder"
                        android:textColor="@color/md_theme_on_surface_variant"
                        android:textSize="16sp"
                        android:visibility="gone" />

                </FrameLayout>

            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:id="@+id/panelDivider"
            android:layout_width="@dimen/dual_panel_divider_width"
            android:layout_height="match_parent"
            android:background="@color/md_theme_outline_variant" />

        <!-- Right Panel -->
        <LinearLayout
            android:id="@+id/rightPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@color/md_theme_background">

            <!-- Active Panel Indicator (Right) -->
            <View
                android:id="@+id/rightPanelIndicator"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="@color/md_theme_primary"
                android:visibility="invisible" />

            <!-- Right Panel File List -->
            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipeRightRefresh"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRightFiles"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:paddingVertical="@dimen/spacing_xs"
                        tools:listitem="@layout/item_file" />

                    <TextView
                        android:id="@+id/tvRightEmpty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/empty_folder"
                        android:textColor="@color/md_theme_on_surface_variant"
                        android:textSize="16sp"
                        android:visibility="gone" />

                </FrameLayout>

            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
