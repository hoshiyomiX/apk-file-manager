<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootPanel"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    tools:context=".ui.main.MainActivity">

    <!-- Left Panel -->
    <LinearLayout
        android:id="@+id/leftPanel"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Left Panel Toolbar -->
        <LinearLayout
            android:id="@+id/leftPanelToolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/md_theme_surface"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_sm"
            android:elevation="2dp">

            <ImageButton
                android:id="@+id/btnLeftUp"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_arrow_up"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/up"
                app:tint="@color/md_theme_on_surface" />

            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none"
                android:layout_marginStart="@dimen/spacing_sm">

                <TextView
                    android:id="@+id/tvLeftPath"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="middle"
                    android:textColor="@color/md_theme_on_surface"
                    android:textSize="14sp"
                    android:paddingVertical="4dp" />

            </HorizontalScrollView>

            <ImageButton
                android:id="@+id/btnLeftRefresh"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_rotate"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/refresh"
                app:tint="@color/md_theme_on_surface" />

            <ImageButton
                android:id="@+id/btnLeftMore"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_more_vert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/more_options"
                app:tint="@color/md_theme_on_surface" />

        </LinearLayout>

        <!-- Left Panel File List -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeLeftRefresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvLeftFiles"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingVertical="@dimen/spacing_xs"
                    tools:listitem="@layout/item_file" />

                <TextView
                    android:id="@+id/tvLeftEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/empty_folder"
                    android:textColor="@color/md_theme_on_surface_variant"
                    android:textSize="16sp"
                    android:visibility="gone" />

            </FrameLayout>

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:id="@+id/panelDivider"
        android:layout_width="@dimen/dual_panel_divider_width"
        android:layout_height="match_parent"
        android:background="@color/md_theme_outline_variant" />

    <!-- Right Panel -->
    <LinearLayout
        android:id="@+id/rightPanel"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Right Panel Toolbar -->
        <LinearLayout
            android:id="@+id/rightPanelToolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/md_theme_surface"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_sm"
            android:elevation="2dp">

            <ImageButton
                android:id="@+id/btnRightUp"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_arrow_up"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/up"
                app:tint="@color/md_theme_on_surface" />

            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none"
                android:layout_marginStart="@dimen/spacing_sm">

                <TextView
                    android:id="@+id/tvRightPath"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="middle"
                    android:textColor="@color/md_theme_on_surface"
                    android:textSize="14sp"
                    android:paddingVertical="4dp" />

            </HorizontalScrollView>

            <ImageButton
                android:id="@+id/btnRightRefresh"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_rotate"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/refresh"
                app:tint="@color/md_theme_on_surface" />

            <ImageButton
                android:id="@+id/btnRightMore"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_more_vert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/more_options"
                app:tint="@color/md_theme_on_surface" />

        </LinearLayout>

        <!-- Right Panel File List -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRightRefresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRightFiles"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingVertical="@dimen/spacing_xs"
                    tools:listitem="@layout/item_file" />

                <TextView
                    android:id="@+id/tvRightEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/empty_folder"
                    android:textColor="@color/md_theme_on_surface_variant"
                    android:textSize="16sp"
                    android:visibility="gone" />

            </FrameLayout>

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

</LinearLayout>
